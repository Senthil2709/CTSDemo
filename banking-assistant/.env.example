# Copy this file to .env and adjust values as needed, then run:
#   docker compose --env-file .env up --build

# --- Database ---
DB_NAME=banking_assistant
DB_USER=banking_user
DB_PASSWORD=banking_pass

# --- JWT ---
# Use a long, random string in production (32+ characters / 256+ bits).
JWT_SECRET=change-this-super-secret-key-in-production-min-256-bits-long
JWT_EXPIRATION_MS=86400000

# --- Conversational memory ---
# Minutes of inactivity after which a chat session is auto-expired.
CHAT_SESSION_TIMEOUT_MIN=60

# --- OpenAI (optional) ---
# If left blank, the app runs in "offline" mode: intent classification,
# policy answers, and response merging fall back to deterministic,
# rule-based logic instead of calling an LLM.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# --- CORS (only relevant if you run the Angular dev server separately) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8081
